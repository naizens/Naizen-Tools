{
  "name": "naizen-tools",
  "version": "0.5.1",
  "description": "Naizen-Tools – Key Injector & AFK Utility",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE=&& electron-vite dev",
    "build": "set ELECTRON_RUN_AS_NODE=&& electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "dist": "npm run build && electron-builder",
    "dist:analyze": "electron-builder --analyze",
    "postinstall": "electron-rebuild"
  },
  "keywords": [],
  "author": "Naizen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/naizens/Naizen-Tools.git"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-updater": "^6.3.9",
    "irsdk-node": "^4.4.0",
    "koffi": "^3.0.2",
    "lucide-react": "^1.17.0",
    "node-window-manager": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@release-it/conventional-changelog": "^9.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "release-it": "^17.3.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.8.0"
  }
}
